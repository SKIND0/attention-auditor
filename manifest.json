{
  "manifest_version": 3,
  "name": "Attention Auditor",
  "version": "1.0",
  "description": "Tracks browsing habits and provides AI-powered feedback",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "alarms",
    "idle",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.svg",
      "32": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "icons": {
    "16": "icon.svg",
    "32": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}